# =============================================================================
# IdaraOS - Database Initialization Container (Development)
# =============================================================================
#
# Uses the SAME incremental Drizzle migration chain as production:
#   1. pnpm db:migrate:run   — apply pending SQL migrations
#   2. pnpm db:seed           — insert demo data (idempotent, optional)
#   3. pnpm db:seed-rbac      — create roles, permissions, admin user
#   4. pnpm db:post-migrate   — data migrations + RBAC sync (Owner fix)
#
# This ensures local dev behaves identically to Azure deploys.
#
# RAPID PROTOTYPING (optional, use only when you need schema push):
#   docker compose -f docker-compose.dev.yml exec web \
#     sh -c "cd /app/apps/web && npx drizzle-kit push --force && pnpm db:seed-rbac"
#
# =============================================================================

FROM node:22-alpine

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/

RUN pnpm install --frozen-lockfile

COPY apps/web ./apps/web

ENV NODE_ENV=development

CMD ["sh", "-c", "\
echo '=========================================='; \
echo 'IdaraOS Database Migrations (DEV)'; \
echo '=========================================='; \
cd /app/apps/web; \
\
echo ''; \
echo '📋 Running database migrations...'; \
pnpm db:migrate:run; \
\
MIGRATE_EXIT=$?; \
if [ $MIGRATE_EXIT -ne 0 ]; then \
  echo ''; \
  echo '❌ Migration failed with exit code: '$MIGRATE_EXIT; \
  echo ''; \
  echo 'Troubleshooting:'; \
  echo '  1. Check if DATABASE_URL is correct'; \
  echo '  2. Check migration status: pnpm db:migrate:status'; \
  echo '  3. If DB was created with db:push, run: pnpm db:baseline'; \
  echo '  4. For rapid prototyping without migrations:'; \
  echo '     docker compose exec web sh -c \"cd /app/apps/web && npx drizzle-kit push --force\"'; \
  exit 1; \
fi; \
\
echo ''; \
echo '📋 Seeding database...'; \
pnpm db:seed 2>&1 || true; \
\
echo ''; \
echo '📋 Seeding RBAC...'; \
pnpm db:seed-rbac 2>&1 || true; \
\
echo ''; \
echo '📋 Running post-migration hooks...'; \
pnpm db:post-migrate 2>&1 || true; \
\
echo ''; \
echo '=========================================='; \
echo '✅ Database ready!'; \
echo '=========================================='; \
echo ''; \
echo 'Credentials: admin@example.com / Admin123!'; \
"]
